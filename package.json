{
  "name": "wsli",
  "version": "0.2.0",
  "description": "Wealthsimple CLI: GraphQL + Trade REST (accounts, portfolio, buy/sell)",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "wsli": "./dist/index.js"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc -p tsconfig.json",
    "wsli": "node ./dist/index.js",
    "dev": "tsx src/index.ts",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
